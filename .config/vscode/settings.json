{
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.acceptSuggestionOnEnter": "off",
  "editor.accessibilitySupport": "off",
  "editor.codeLens": true,
  "editor.colorDecorators": true,
  "editor.cursorBlinking": "phase",
  "editor.cursorStyle": "underline",
  "editor.emptySelectionClipboard": false,
  "editor.fontFamily": "'FiraCode Nerd Font'",
  "editor.fontLigatures": true,
  "editor.fontSize": 12,
  "editor.fontWeight": "500",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.lightbulb.enabled": false,
  "editor.minimap.enabled": false,
  "editor.multiCursorModifier": "alt",
  "editor.renderIndentGuides": false,
  "editor.renderWhitespace": "selection",
  "editor.smoothScrolling": true,
  "editor.snippetSuggestions": "top",
  "editor.tabCompletion": "onlySnippets",
  "editor.tabSize": 4,
  "editor.wordWrapColumn": 120,
  "explorer.autoReveal": true,
  "explorer.incrementalNaming": "smart",
  "explorer.openEditors.visible": 0,
  "extensions.autoUpdate": false,
  "extensions.closeExtensionDetailsOnViewChange": true,
  "extensions.ignoreRecommendations": true,
  "files.associations": {
    "*.js": "javascript",
    "*.jslib": "javascript",
    "*.jspre": "javascript",
    "*.jsx": "javascriptreact",
    "Brewfile": "ruby",
    "vimrc": "viml"
  },
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "problems.autoReveal": false,
  "security.workspace.trust.untrustedFiles": "open",
  "search.collapseResults": "alwaysCollapse",
  "search.useGlobalIgnoreFiles": true,
  "telemetry.telemetryLevel": "off",
  "terminal.explorerKind": "external",
  "terminal.external.linuxExec": "tilix",
  "terminal.external.osxExec": "kitty",
  "terminal.integrated.cursorStyle": "underline",
  "terminal.integrated.fontSize": 12,
  "update.mode": "none",
  "update.enableWindowsBackgroundUpdates": false,
  "window.enableMenuBarMnemonics": false,
  "window.menuBarVisibility": "hidden",
  "window.titleBarStyle": "native",
  "workbench.activityBar.visible": true,
  "workbench.colorTheme": "Nord",
  "workbench.commandPalette.preserveInput": true,
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editor.focusRecentEditorAfterClose": false,
  "workbench.enableExperiments": false,
  "workbench.iconTheme": "material-icon-theme",
  "workbench.quickOpen.preserveInput": true,
  "workbench.settings.enableNaturalLanguageSearch": false,
  "workbench.sideBar.location": "left",
  "workbench.startupEditor": "welcomePage",
  "workbench.statusBar.feedback.visible": false,
  "workbench.tree.renderIndentGuides": "none",

  /*+--- Extensions ---+*/
  "html.format.indentInnerHtml": true,
  "javascript.preferences.quoteStyle": "double",
  "markdown.preview.breaks": true,
  "markdown.preview.doubleClickToSwitchToEditor": false,
  "markdown.preview.fontFamily": "-apple-system, BlinkMacSystemFont, Inter, sans-serif",
  "markdown.preview.fontSize": 20,
  "omnisharp.useGlobalMono": "always",
  "omnisharp.monoPath": "/Library/Frameworks/Mono.framework/Versions/Current",
  "omnisharp.organizeImportsOnFormat": true,
  "prettier.printWidth": 120,
  "typescript.preferences.quoteStyle": "double",
  "vscode-neovim.neovimExecutablePaths.darwin": "/opt/homebrew/bin/nvim",
  "ttProcessor.TTPath": "\"/Library/Frameworks/Mono.framework/Versions/Current/Commands/mono\" \"/Applications/Visual Studio.app/Contents/Resources/lib/monodevelop/AddIns/MonoDevelop.TextTemplating/TextTransform.exe\"",

  /*+--- Color Theme ---+*/
  "editor.tokenColorCustomizations": {
    "[Nord]": {
      "textMateRules": []
    }
  },
  "material-icon-theme.activeIconPack": "react",
  "material-icon-theme.folders.color": "#616e88",
  "material-icon-theme.folders.theme": "classic",
  "material-icon-theme.hidesExplorerArrows": true,
  "material-icon-theme.saturation": 0.6,
  "workbench.colorCustomizations": {
    "[Nord]": {}
  },

  /*+--- Language Scopes ---+*/
  "[csharp]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp"
  },
  "[markdown]": {
    "editor.quickSuggestions": false,
    "editor.wordWrap": "on"
  },
  "[mdx]": {
    "editor.quickSuggestions": false,
    "editor.wordWrap": "on"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.formatOnType": true,
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
